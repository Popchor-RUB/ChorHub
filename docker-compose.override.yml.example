# Copy this file to docker-compose.override.yml and adjust to your deployment.
# docker-compose.override.yml is gitignored and auto-loaded by Docker Compose.
# It adds Traefik labels and the external traefik network without touching the
# checked-in compose files.

services:
  frontend:
    networks:
      - traefik
    labels:
      - traefik.enable=true
      - traefik.http.routers.chorhub.entrypoints=webNoAuth
      - traefik.http.routers.chorhub.rule=Host(`popchor.rub.de`) && PathPrefix(`/chorhub`)
      - "traefik.http.routers.chorhub.middlewares=chorhub-stripprefix@docker"
      - "traefik.http.middlewares.chorhub-stripprefix.stripprefix.prefixes=/chorhub"
      - traefik.http.routers.chorhub.service=chorhub-service
      - traefik.http.services.chorhub-service.loadbalancer.server.port=80

  mailhog:
    networks:
      - traefik
    labels:
      - traefik.enable=true
      - traefik.http.routers.mailhog.entrypoints=web
      - traefik.http.routers.mailhog.rule=Host(`mailhog.example.com`)
      - traefik.http.routers.mailhog.service=mailhog-service
      - traefik.http.services.mailhog-service.loadbalancer.server.port=8025

networks:
  traefik:
    external: true
