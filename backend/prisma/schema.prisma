generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum AttendanceResponse {
  CONFIRMED
  DECLINED
}

model Member {
  id           String     @id @default(uuid())
  firstName    String
  lastName     String
  email        String      @unique
  choirVoiceId String?     @map("choir_voice_id")
  choirVoice   ChoirVoice? @relation(fields: [choirVoiceId], references: [id])
  lastLoginAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  loginCodes       MemberLoginCode[]
  loginTokens       MemberLoginToken[]
  attendancePlans   AttendancePlan[]
  attendanceRecords AttendanceRecord[]
  pushSubscriptions PushSubscription[]

  @@map("members")
}

model MemberLoginCode {
  id         String   @id @default(uuid())
  memberId   String
  hashedCode String
  expiresAt  DateTime
  member     Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([memberId, hashedCode])
  @@index([expiresAt])
  @@map("member_login_codes")
}

model MemberLoginToken {
  id          String   @id @default(uuid())
  memberId    String
  hashedToken String   @unique
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@map("member_login_tokens")
}

model PushSubscription {
  id        String   @id @default(cuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@map("push_subscriptions")
}

model Rehearsal {
  id          String   @id @default(uuid())
  date        DateTime
  title       String
  description String?
  location    String?
  durationMinutes Int? @map("duration_minutes")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attendancePlans   AttendancePlan[]
  attendanceRecords AttendanceRecord[]

  @@map("rehearsals")
}

model AttendancePlan {
  id          String             @id @default(uuid())
  memberId    String
  rehearsalId String
  response    AttendanceResponse
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  member    Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  rehearsal Rehearsal @relation(fields: [rehearsalId], references: [id], onDelete: Cascade)

  @@unique([memberId, rehearsalId])
  @@map("attendance_plans")
}

model AttendanceRecord {
  id          String   @id @default(uuid())
  memberId    String
  rehearsalId String
  createdAt   DateTime @default(now())

  member    Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  rehearsal Rehearsal @relation(fields: [rehearsalId], references: [id], onDelete: Cascade)

  @@unique([memberId, rehearsalId])
  @@map("attendance_records")
}

model AdminUser {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  passkeyCredentials PasskeyCredential[]

  @@map("admin_users")
}

model PasskeyCredential {
  id           String   @id @default(uuid())
  adminUserId  String
  credentialId String   @unique
  publicKey    Bytes
  counter      BigInt   @default(0)
  deviceType   String?
  backedUp     Boolean  @default(false)
  transports   String[]
  createdAt    DateTime @default(now())

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@map("passkey_credentials")
}

model GeneralInfo {
  id              String   @id @default(cuid())
  markdownContent String
  updatedAt       DateTime @updatedAt

  @@map("general_info")
}

model ChoirVoice {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  members   Member[]

  @@map("choir_voices")
}
