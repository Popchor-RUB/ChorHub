<!DOCTYPE html>
<html lang="de" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title>Willkommen bei ChorHub</title>
  <!--[if mso]>
  <noscript>
    <xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml>
  </noscript>
  <![endif]-->
</head>
<body style="margin: 0; padding: 0; background-color: #f4f4f4; font-family: Arial, sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" border="0" bgcolor="#f4f4f4">
    <tr>
      <td align="center" style="padding: 32px 16px;">

        <!-- Card -->
        <table width="600" cellpadding="0" cellspacing="0" border="0" bgcolor="#ffffff" style="max-width: 600px; border-radius: 8px; overflow: hidden;">
          <tr>
            <td style="padding: 32px 40px;">

              <!-- Heading -->
              <h1 style="margin: 0 0 16px 0; font-family: Arial, sans-serif; font-size: 24px; font-weight: bold; color: #1a1a1a;">
                Willkommen, {{firstName}} {{lastName}}!
              </h1>

              <!-- Body text -->
              <p style="margin: 0 0 32px 0; font-family: Arial, sans-serif; font-size: 16px; line-height: 1.6; color: #444444;">
                Du wurdest als Mitglied in ChorHub aufgenommen. Mit dem Button unten kannst du dich jederzeit in deinen persönlichen Bereich einloggen:
              </p>

              <!-- Bulletproof button -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="padding: 0 0 32px 0;">
                    <!--[if mso]>
                    <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word"
                      href="{{magicUrl}}" style="height:50px;v-text-anchor:middle;width:200px;" arcsize="16%" fillcolor="#006FEE" strokecolor="#006FEE">
                      <w:anchorlock/>
                      <center style="color:#ffffff;font-family:Arial,sans-serif;font-size:16px;font-weight:bold;">Zu ChorHub</center>
                    </v:roundrect>
                    <![endif]-->
                    <!--[if !mso]><!-->
                    <a href="{{magicUrl}}" target="_blank"
                       style="background-color: #006FEE; color: #ffffff; display: inline-block; font-family: Arial, sans-serif;
                              font-size: 16px; font-weight: bold; line-height: 1; padding: 16px 36px;
                              text-decoration: none; border-radius: 8px; mso-hide: all;">
                      Zu ChorHub
                    </a>
                    <!--<![endif]-->
                  </td>
                </tr>
              </table>

              <!-- Note -->
              <p style="margin: 0 0 24px 0; font-family: Arial, sans-serif; font-size: 14px; line-height: 1.6; color: #888888;">
                Bitte speichere diesen Link – er ist dein persönlicher Zugang zu ChorHub. Teile ihn nicht mit anderen.
              </p>

              <!-- Divider -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="border-top: 1px solid #eeeeee; padding-top: 24px;">
                    <p style="margin: 0; font-family: Arial, sans-serif; font-size: 12px; color: #aaaaaa;">
                      ChorHub – Chororganisation
                    </p>
                  </td>
                </tr>
              </table>

            </td>
          </tr>
        </table>
        <!-- /Card -->

      </td>
    </tr>
  </table>
</body>
</html>
