<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{title}}</title>
</head>
<body style="margin:0;padding:0;background:#f4f4f4;font-family:Arial,sans-serif;color:#1a1a1a;">
  <table width="100%" cellpadding="0" cellspacing="0" border="0" bgcolor="#f4f4f4">
    <tr>
      <td align="center" style="padding:24px 12px;">
        <table width="600" cellpadding="0" cellspacing="0" border="0" bgcolor="#ffffff" style="max-width:600px;border-radius:8px;">
          <tr>
            <td style="padding:28px;">
              <h1 style="margin:0 0 12px 0;font-size:24px;">Hallo {{firstName}},</h1>
              <p style="margin:0 0 16px 0;line-height:1.6;">{{intro}}</p>

              <ul style="margin:0 0 16px 0;padding:0;line-height:1.6;list-style:none;">
                {{#each items}}
                <li style="margin:0 0 12px 0;padding:0;">
                  <p style="margin:0 0 8px 0;">{{label}}</p>
                  {{#if confirmUrl}}
                  <p style="margin:0 0 4px 0;">
                    <a href="{{confirmUrl}}" target="_blank"
                       style="background:#17c964;color:#ffffff;text-decoration:none;padding:9px 14px;border-radius:8px;display:inline-block;font-weight:bold;margin-right:6px;">
                      Ich komme
                    </a>
                    <a href="{{declineUrl}}" target="_blank"
                       style="background:#f31260;color:#ffffff;text-decoration:none;padding:9px 14px;border-radius:8px;display:inline-block;font-weight:bold;">
                      Ich komme nicht
                    </a>
                  </p>
                  {{/if}}
                </li>
                {{/each}}
              </ul>

              {{#if question}}
              <p style="margin:0 0 20px 0;line-height:1.6;"><strong>{{question}}</strong></p>
              {{/if}}

              {{#if showGenericLogin}}
              <p style="margin:0 0 20px 0;line-height:1.6;">Melde dich direkt über deinen Link an:</p>

              <p style="margin:0 0 24px 0;">
                <a href="{{magicUrl}}" target="_blank"
                   style="background:#006FEE;color:#ffffff;text-decoration:none;padding:12px 20px;border-radius:8px;display:inline-block;font-weight:bold;">
                  Jetzt anmelden
                </a>
              </p>

              <p style="margin:0;font-size:13px;color:#666;word-break:break-all;">
                Falls der Button nicht funktioniert: <a href="{{magicUrl}}" target="_blank">{{magicUrl}}</a>
              </p>
              {{/if}}

              <p style="margin:20px 0 0 0;line-height:1.6;">
                Vielen Dank für deine Unterstützung und dass du dir kurz Zeit für eine Rückmeldung nimmst.
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
