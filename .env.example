# Database
POSTGRES_USER=chorhub
POSTGRES_PASSWORD=chorhub_secret
POSTGRES_DB=chorhub
DATABASE_URL=postgresql://chorhub:chorhub_secret@localhost:5432/chorhub

# JWT
JWT_SECRET=change_me_to_a_long_random_secret

# Email (development: uses MailHog on localhost:1025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@chorhub.de

# App
APP_URL=http://localhost:5173
NODE_ENV=development

# QR Check-In signing (Ed25519, base64-encoded DER keys)
QR_CHECKIN_PRIVATE_KEY_BASE64=change_me
QR_CHECKIN_PUBLIC_KEY_BASE64=change_me

# Frontend build (optional)
# Set this if deploying to a subpath, e.g., BASE_PATH=/chorhub/
BASE_PATH=/
