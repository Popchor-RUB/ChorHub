# Frontend environment variables — production mode.
# Run ./setup-secrets.sh to generate frontend/.env.production (symlinked as .env.frontend).
# Vite loads this file automatically when building for production (npm run build).
# Docker's COPY . . includes this file in the build context (not affected by .gitignore).
VITE_API_URL=https://example.com/chorhub/api
VITE_BASE_PATH=/chorhub/
