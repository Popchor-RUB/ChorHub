# Backend secrets — injected only into the backend container.
# Run ./setup-secrets.sh to generate .env.backend with secure random values.

# Database (must match .env.db)
DATABASE_URL=postgresql://chorhub:change_me@db:5432/chorhub

# JWT
JWT_SECRET=change_me_to_a_long_random_secret

# Email (production: set real SMTP credentials)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@chorhub.de

# App
APP_URL=https://example.com/chorhub/
NODE_ENV=production

# Web Push (VAPID) — run ./setup-secrets.sh to generate
VAPID_PUBLIC_KEY=change_me
VAPID_PRIVATE_KEY=change_me
VAPID_EMAIL=mailto:admin@example.com
